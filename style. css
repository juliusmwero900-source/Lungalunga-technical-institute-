body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: url('../images/library.jpg') no-repeat center center fixed;
    background-size: cover;
    color: #fff;
}
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    background-color: rgba(0,0,0,0.7);
}
header h1 { font-size: 16px; font-weight: bold; }
header .nav-buttons button {
    margin-left: 10px;
    padding: 5px 10px;
    font-weight: bold;
    cursor: pointer;
}
.container { padding: 20px; text-align: center; }
.courses-list span, .courses span {
    display: block;
    font-weight: bold;
    text-decoration: underline;
    font-size: 20px;
    margin: 10px 0;
    cursor: pointer;
}
.footer-message { font-weight: bold; margin-top: 30px; }
nav a { color: #fff; margin: 0 10px; font-weight: bold; text-decoration: none; }
nav { margin-top: 20px; display: block; }
input { margin: 5px 0; padding: 5px; width: 200px; }
button { padding: 5px 10px; cursor: pointer; font-weight: bold; }
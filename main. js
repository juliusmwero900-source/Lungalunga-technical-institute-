// Password strength checker
function checkStrength(){
    const pw = document.getElementById('password').value;
    const strength = document.getElementById('strength');
    if(pw.length < 4) strength.innerText = "Weak"; 
    else if(pw.length < 8) strength.innerText = "Medium";
    else strength.innerText = "Strong";
}

// Registration form handler
function registerUser(){
    const username = document.getElementById('username').value;
    const course = document.getElementById('course').value;
    const password = document.getElementById('password').value;
    let users = JSON.parse(localStorage.getItem('users') || '[]');
    if(users.find(u=>u.username===username)){
        document.getElementById('message').innerText = "Username already exists!";
        return;
    }
    users.push({username, course, password});
    localStorage.setItem('users', JSON.stringify(users));
    document.getElementById('message').innerText = "Registration successful!";
}

// Login form handler
function loginUser(){
    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;
    let users = JSON.parse(localStorage.getItem('users') || '[]');
    const user = users.find(u=>u.username===username && u.password===password);
    if(user){
        localStorage.setItem('currentUser', username);
        window.location.href = "courses.html";
    } else {
        document.getElementById('message').innerText = "Incorrect credentials. Please register!";
    }
}